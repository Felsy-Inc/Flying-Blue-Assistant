## Flying Blue Assistant — copy to `.env` and adjust per environment.
## See README.md and docs/ARCHITECTURE.md for how these fit together.

# --- Database (optional local tooling / migrations) ---
DATABASE_URL=postgresql://...

# --- Supabase (Auth + Postgres) ---
# Enables @nuxtjs/supabase when URL + anon key are set.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<anon publishable key>
NUXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=<anon publishable key>
# Server-only: RLS bypass for workers, cache, webhooks. Never ship to the browser.
SUPABASE_SECRET_KEY=

# Base URL for magic links and email redirects (must match Supabase Auth URL settings)
NUXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (transactional email, e.g. alert notifications) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com
# Allow overriding `to` on test-alert endpoint outside dev (default: dev-only)
# EMAIL_TEST_ALLOW_TO_OVERRIDE=true

# --- Stripe (subscriptions; server-side secrets) ---
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# --- Cron / scheduled jobs (Vercel Cron or external ping) ---
# Caller must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Feature flags ---
# Award search uses mock data when true; set false when a real provider exists.
USE_MOCK_PROVIDER=true
# Master switch for sending email (Resend).
EMAILS_ENABLED=true
# Legacy/public browse redirect; see nuxt.config if still wired.
PUBLIC_BROWSE_ENABLED=true
# Show upgrade + portal UI; must align with NUXT_PUBLIC_BILLING_ENABLED for the client.
BILLING_ENABLED=false
# NUXT_PUBLIC_BILLING_ENABLED=true

# --- Debug / build ---
# NUXT_SOURCEMAP=true
